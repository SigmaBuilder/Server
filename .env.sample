# ── Server ────────────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=3000

# ── Database (PostgreSQL) ─────────────────────────────────────────────────────
# Connection details for the PostgreSQL instance (local Docker or production).
# These values are consumed by Knex via src/config/db.js.
DB_HOST=localhost
DB_PORT=5432
DB_NAME=sigmabuilder
DB_USER=your_db_user
DB_PASS=your_db_password

# ── JWT Access Token ───────────────────────────────────────────────────────────
# Short-lived. Sent in Authorization: Bearer <token> header by the client.
# Must be at least 32 characters of random data.
JWT_ACCESS_SECRET=change_me_min_32_chars_random_string
JWT_ACCESS_EXPIRES_IN=15m

# ── JWT Refresh Token ──────────────────────────────────────────────────────────
# Long-lived. Stored as HttpOnly cookie. Hashed before persisting to DB.
# Use a DIFFERENT secret from JWT_ACCESS_SECRET.
JWT_REFRESH_SECRET=change_me_min_32_chars_different_secret
JWT_REFRESH_EXPIRES_IN=7d

# ── CORS ───────────────────────────────────────────────────────────────────────
# Comma-separated origins allowed to send credentials (cookies).
CORS_ORIGIN=http://localhost:5173,http://localhost:4000

# ── Rate Limiting (auth routes) ────────────────────────────────────────────────
# RATE_LIMIT_WINDOW_MS: 900000 = 15 minutes
# RATE_LIMIT_MAX: max requests per window per IP
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=20

# ── AI Provider (OpenAI Compatible) ──────────────────────────────────────────
# Configuration for the AI assistant. Supports OpenAI, Ollama, OpenRouter, etc.
AI_BASE_URL=http://54.166.147.168:11434/v1
AI_MODEL=qwen2:0.5b
AI_API_KEY=ollama

# ── Resend ────────────────────────────────────────────────
RESEND_API_KEY=re_xxx

# AWS S3 Settings
AWS_REGION=eu-west-1
AWS_ACCESS_KEY_ID=xxx
AWS_SECRET_ACCESS_KEY=xxx
AWS_S3_BUCKET=sigmabuilder-media
