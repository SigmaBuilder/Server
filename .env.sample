# ── Server ────────────────────────────────────────────────────────────────────
NODE_ENV=test
PORT=3000

# ── Database (PostgreSQL) ─────────────────────────────────────────────────────
DB_HOST=db
DB_PORT=5432
DB_NAME=sigmabuilder
DB_USER=sigma
DB_PASS=sigma_pass

# ── JWT Access Token ───────────────────────────────────────────────────────────
# Short-lived. Sent in Authorization: Bearer <token> header by the client.
# Cambia estas claves por cadenas aleatorias seguras de más de 32 caracteres.
JWT_ACCESS_SECRET=sigma_access_secret_change_me_in_prod_32c
JWT_ACCESS_EXPIRES_IN=15m

# ── JWT Refresh Token ──────────────────────────────────────────────────────────
# Long-lived. Stored as HttpOnly cookie. Hashed before persisting to DB.
JWT_REFRESH_SECRET=sigma_refresh_secret_change_me_in_prod_32c
JWT_REFRESH_EXPIRES_IN=7d

# ── CORS ───────────────────────────────────────────────────────────────────────
CORS_ORIGIN=http://localhost:5173, http://localhost:4000

# ── Rate Limiting (auth routes) ────────────────────────────────────────────────
# RATE_LIMIT_WINDOW_MS: 900000 = 15 minutes
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=20

# ── Resend ────────────────────────────────────────────────
RESEND_API_KEY=re_your_resend_api_key_placeholder

# AWS S3 Settings
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=your_aws_access_key_id
AWS_SECRET_ACCESS_KEY=your_aws_secret_access_key
AWS_S3_BUCKET=your_s3_bucket_name

# Para usar Supabase Storage u otro proveedor compatible con S3
AWS_ENDPOINT=https://your-project-id.storage.supabase.co/storage/v1/s3
STORAGE_PUBLIC_URL_BASE=https://your-project-id.supabase.co/storage/v1/object/public/your-bucket-name

# ── AI Provider (OpenAI Compatible) ──────────────────────────────────────────
# Configuration for the AI assistant. Supports OpenAI, Ollama, OpenRouter, etc.
AI_BASE_URL=https://models.github.ai/inference
AI_MODEL=openai/gpt-4.1
AI_API_KEY=your_github_pat_or_openai_api_key

DB_SSL=false

PUBLIC_URL_API=http://localhost:3000/api/v1

PUBLIC_URL_CLIENT=http://localhost:5173

COMPOSE_PROFILES=development