# Environment Configuration for Tests
NODE_ENV=test
PORT=3000

# Database Configuration (matches CI Postgres service and docker-compose default)
DB_HOST=localhost
DB_PORT=5432
DB_NAME=sigmabuilder
DB_USER=sigma
DB_PASS=sigma_pass

# Dummy secrets for JWT
JWT_ACCESS_SECRET=github_actions_dummy_access_secret_123
JWT_REFRESH_SECRET=github_actions_dummy_refresh_secret_123
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# Dummy key for Resend integration
RESEND_API_KEY=re_dummy_key_for_testing

# Dummy credentials for AWS S3 Storage
AWS_REGION=eu-west-1
AWS_ACCESS_KEY_ID=dummy
AWS_SECRET_ACCESS_KEY=dummy
AWS_S3_BUCKET=dummy-bucket
